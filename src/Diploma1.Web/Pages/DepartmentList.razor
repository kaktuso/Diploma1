@page "/departments"
@inject Diploma1.Web.Services.DepartmentService DepartmentService

<h3>Отделы</h3>
@if (departments == null)
{
    <p>Загрузка...</p>
}
else
{
    <table>
        <thead>
            <tr>
                <th>Название</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var dep in departments)
            {
                <tr>
                    <td>@dep.Name</td>
                    <td>
                        <button @onclick="() => Edit(dep.Id)">Изменить</button>
                        <button @onclick="() => Delete(dep.Id)">Удалить</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    List<Diploma1.Web.Models.DepartmentDto>? departments;
    protected override async Task OnInitializedAsync()
    {
        departments = await DepartmentService.GetAllAsync();
    }
    void Edit(Guid id) { /* переход на страницу редактирования */ }
    async Task Delete(Guid id)
    {
        await DepartmentService.DeleteAsync(id);
        departments = await DepartmentService.GetAllAsync();
    }
}
